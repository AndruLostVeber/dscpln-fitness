generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
}

enum FitnessGoal {
  lose_weight
  gain_muscle
  maintain
  improve_endurance
  flexibility
}

enum FitnessLevel {
  beginner
  intermediate
  advanced
}

enum MotivationStyle {
  light
  medium
  hard
}

enum ActivityLevel {
  sedentary
  lightly_active
  moderately_active
  very_active
}

enum DietPreference {
  omnivore
  vegetarian
  vegan
  keto
  none
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         UserProfile?
  sessions        Session[]
  workoutSessions WorkoutSession[]
  chatMessages    ChatMessage[]

  @@map("users")
}


model UserProfile {
  id              String          @id @default(uuid())
  userId          String          @unique
  dateOfBirth     DateTime
  gender          Gender
  heightCm        Int
  weightKg        Float
  goal            FitnessGoal
  fitnessLevel    FitnessLevel
  motivationStyle MotivationStyle
  activityLevel   ActivityLevel?
  workoutsPerWeek Int?
  injuries        String[]
  dietPreference  DietPreference?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model WorkoutSession {
  id          String            @id @default(uuid())
  userId      String
  title       String
  durationMin Int
  notes       String?
  createdAt   DateTime          @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@map("workout_sessions")
}

model WorkoutExercise {
  id          String  @id @default(uuid())
  sessionId   String
  name        String
  sets        Int
  reps        Int?
  weightKg    Float?
  durationSec Int?
  notes       String?

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("workout_exercises")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}
